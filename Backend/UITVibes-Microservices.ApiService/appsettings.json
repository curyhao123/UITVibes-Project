{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "UITVibes.AuthService",
    "Audience": "UITVibes.Client",
    "ExpiresInMinutes": "60",
    "RefreshTokenExpiresInDays": "7"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/{**catch-all}"
          }
        ]
      },
      "user-follow-route": {
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/user/follow/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/follow/{**catch-all}"
          }
        ]
      },
      "user-profile-route": {
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/user/userprofile/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/userprofile/{**catch-all}"
          }
        ]
      },
      "user-block-route": {
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/user/block/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/block/{**catch-all}"
          }
        ]
      },
      "post-route": {
        "ClusterId": "post-cluster",
        "Match": {
          "Path": "/post/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/post/{**catch-all}"
          }
        ]
      },
      "story-route": {
        "ClusterId": "post-cluster",
        "Match": {
          "Path": "/story/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/story/{**catch-all}"
          }
        ]
      },
      "message-conversation-route": {
        "ClusterId": "message-cluster",
        "Match": {
          "Path": "/message/conversations/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/conversation/{**catch-all}"
          }
        ]
      },
      "message-message-route": {
        "ClusterId": "message-cluster",
        "Match": {
          "Path": "/message/conversations/{conversationId}/messages/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/conversation/{conversationId}/message/{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5158"
          }
        }
      },
      "user-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5016"
          }
        }
      },
      "post-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5078"
          }
        }
      },
      "message-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5240"
          }
        }
      }
    }
  }
}